import camion.*
import cosas.*

describe "Test paquete, batería, contendor y embalaje" {

  test "El contendor pesa 960 si le metemos embalaje, bumblebee y residuos de 30 kg" {
    residuos.peso(30)
    embalaje.cambiarLoQueEnvuelve(residuos)
    contenedor.meterElementos([ embalaje, residuos, bumblebee ])
    assert.equals(30+30+800+100, contenedor.peso())
  }
}